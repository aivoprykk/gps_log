# GPS Log Test Example - sdkconfig defaults

# Enable GPS log component
CONFIG_GPS_LOG_ENABLED=y
CONFIG_GPS_LOG_STACK_SIZE=8192
CONFIG_LOGGER_VFS_ENABLED=y
CONFIG_LOGGER_UBX_ENABLED=y
CONFIG_GPS_LOG_LEVEL_INFO=y

# Use static buffers for GPS (avoid dynamic allocation issues)
CONFIG_GPS_LOG_STATIC_A_BUFFER=y
CONFIG_GPS_LOG_STATIC_S_BUFFER=y

# Enable ESP32 Task Watchdog
CONFIG_ESP_TASK_WDT=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=y
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=y

# Increase main task stack size
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# FreeRTOS configuration
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_WATCHPOINT_END_OF_STACK=y

# ESP Event Loop
CONFIG_ESP_EVENT_LOOP_STACK_SIZE=4096

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y

# UART configuration (not used but component requires it)
CONFIG_LOGGER_UBX_UART_NUM=1
CONFIG_LOGGER_UBX_UART_BAUD_RATE=115200
CONFIG_LOGGER_UBX_UART_RXD_PIN=16
CONFIG_LOGGER_UBX_UART_TXD_PIN=17

# Disable components we don't need for testing
CONFIG_LOGGER_WIFI_ENABLED=n
CONFIG_LOGGER_HTTP_ENABLED=n
CONFIG_DISPLAY_ENABLED=n
CONFIG_LOGGER_ADC_ENABLED=n
CONFIG_LOGGER_BUTTON_ENABLED=n
